# sy01b-server config — copy to server/pump.toml and edit for your bench.

[pump]
# CH340 USB-RS232 dongle, matched by USB identity so it survives a
# /dev/ttyUSB* renumber or a different USB socket. The SY-01B's CH340
# exposes no serial number, so VID:PID alone is used (it is the only
# CH340 on the bench). If two identical dongles ever coexist and expose
# serials, pin one with "VID:PID:SERIAL". See DESIGN.md §4.1.
port = "1A86:7523"
address = 1
baud = 9600
syringe_uL = 125
step_mode = "N0"
reply_timeout_s = 1.0

[server]
# 0.0.0.0 so the LAN-side ESP32 can reach the bridge.
# PC host LAN IP is 192.168.1.129 on this bench; clients hit that addr.
host = "0.0.0.0"
port = 17046
log_level = "info"
